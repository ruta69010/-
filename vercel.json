{
  "functions": {
    "api/predict.js": {
      "maxDuration": 30
    },
    "api/active-tracks.js": {
      "maxDuration": 10
    },
    "api/sitemap.js": {
      "maxDuration": 5
    }
  },
  "routes": [
    {
      "src": "/sitemap.xml",
      "dest": "/api/sitemap"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
